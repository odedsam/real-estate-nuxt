# Normalize text files and keep repository line endings stable.
* text=auto eol=lf

# Scripts and hooks should always use LF.
*.sh text eol=lf
*.bash text eol=lf
*.zsh text eol=lf
.husky/* text eol=lf

# Windows-native scripts keep CRLF when present.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Common binary assets.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.avif binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.eot binary
*.zip binary
*.gz binary
*.tgz binary
*.mp4 binary
*.webm binary
